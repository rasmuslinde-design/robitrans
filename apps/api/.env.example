# API config
PORT=5175
ORIGIN=http://localhost:5173
DATABASE_PATH=./data/robitrans.sqlite

# Admin login
ADMIN_USER=admin
ADMIN_PASS=qwerty123
# Simple bearer token returned by /api/admin/login
ADMIN_TOKEN=dev-admin-token-change-me

# Mail (SMTP)
# If these are missing, API will still accept bookings but will SKIP email sending.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_user
SMTP_PASS=your_pass

MAIL_FROM="RobiTrans <no-reply@robitrans.ee>"
MAIL_TO=bert-robert.polluste@voco.ee
